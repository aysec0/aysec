# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-too

# Database
# Local dev: leave empty to use ./data/app.db
# Production (Turso/libsql): set TURSO_URL + TURSO_AUTH_TOKEN
DATABASE_URL=
TURSO_URL=
TURSO_AUTH_TOKEN=

# Stripe (paid courses)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Site
SITE_URL=http://localhost:3000
SITE_NAME=Aysec

# Discord
# Public invite link — used everywhere the site says "Join Discord"
DISCORD_INVITE_URL=
# Server ID — enables the live "members online" widget on /community.
# Discord → Server Settings → Widget → enable widget → copy Server ID.
DISCORD_SERVER_ID=
# Incoming webhook URL — used to push announcements to a #announcements channel.
# In Discord: channel → Edit Channel → Integrations → Webhooks → New Webhook → copy URL.
DISCORD_WEBHOOK_URL=
